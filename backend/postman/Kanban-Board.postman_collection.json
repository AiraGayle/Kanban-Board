        {
          "name": "POST /tasks — conflict resolution (stale update rejected)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Step 1: generate a fresh UUID for this conflict test",
                  "const uuid = require('uuid');",
                  "const id = uuid.v4();",
                  "pm.environment.set('conflict_task_id', id);",
                  "",
                  "// Step 2: create the task NOW with a current timestamp so the server has a fresh copy.",
                  "// The main request will then try to overwrite it with a 2020 timestamp — which should be rejected.",
                  "const baseUrl = pm.environment.get('base_url');",
                  "const token   = pm.environment.get('token');",
                  "",
                  "pm.sendRequest({",
                  "    url:    baseUrl + '/tasks',",
                  "    method: 'POST',",
                  "    header: {",
                  "        'Content-Type':  'application/json',",
                  "        'Authorization': 'Bearer ' + token",
                  "    },",
                  "    body: {",
                  "        mode: 'raw',",
                  "        raw: JSON.stringify({",
                  "            id:          id,",
                  "            title:       'Conflict base — current version',",
                  "            note:        '',",
                  "            column_name: 'to-do',",
                  "            priority:    'Low',",
                  "            task_order:  0,",
                  "            deleted:     false,",
                  "            updated_at:  new Date().toISOString()",
                  "        })",
                  "    }",
                  "}, (err, res) => {",
                  "    if (err) console.error('Pre-request create failed:', err);",
                  "});"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// The main request sent updated_at: 2020-01-01 against a task the server",
                  "// already has with a 2026 timestamp. The ON CONFLICT guard should reject",
                  "// the stale write and return the server's current version instead.",
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "",
                  "pm.test('Server returns a task object', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.property('task');",
                  "    pm.expect(body.task).to.not.be.null;",
                  "});",
                  "",
                  "pm.test('Server kept its newer title (stale write was rejected)', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.task.title).to.eql('Conflict base — current version');",
                  "});",
                  "",
                  "pm.test('Server kept its newer column (stale write was rejected)', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.task.column_name).to.eql('to-do');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
